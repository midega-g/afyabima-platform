# =============================================================================
# AfyaBima — Environment variables template
# =============================================================================
# Copy this file to .env and fill in real values before running:
#   cp .env.example .env
#
# .env is in .gitignore — never commit it.
# This file (.env.example) IS committed — it documents what is required.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL — superuser (used only for initdb and admin tasks)
# ---------------------------------------------------------------------------
POSTGRES_DB=afyabima
POSTGRES_USER=afyabima_admin
POSTGRES_PASSWORD=change_me_strong_password_here

# ---------------------------------------------------------------------------
# Service role passwords (set by docker/postgres/initdb/02_set_passwords.sh)
# Each role has the minimum privileges required — see schema.sql Section 1.
# ---------------------------------------------------------------------------

# kafka_connect: INSERT/UPDATE/DELETE on raw.* (Scenario B streaming)
KAFKA_CONNECT_PASSWORD=change_me

# dbt_runner: SELECT on raw.*, ALL on staging/intermediate/marts
DBT_RUNNER_PASSWORD=change_me

# api_reader: SELECT on marts.* only (FastAPI read-only access)
API_READER_PASSWORD=change_me

# debezium: REPLICATION privilege (CDC on raw.fraud_investigation_outcomes)
DEBEZIUM_PASSWORD=change_me

# airflow_runner: SELECT on raw.*/marts.*, INSERT on raw.model_performance_log
AIRFLOW_RUNNER_PASSWORD=change_me

# ---------------------------------------------------------------------------
# Airflow (uncomment when enabling the airflow service)
# ---------------------------------------------------------------------------
# AIRFLOW_FERNET_KEY=generate_with__python_-c_"from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())"
